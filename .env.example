# Copy this file to .env and fill in your values.
#   cp .env.example .env
# .env is gitignored — never commit your real key.

# TensorMesh serverless API key (required for the live-call / aiperf cells).
# Get one at https://docs.tensormesh.ai/
TENSORMESH_API_KEY=ak-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides (defaults shown).
# TENSORMESH_BASE_URL=https://serverless.tensormesh.ai
